  @@index([pidUser])
}

model Transaction {
  id          String          @id @default(cuid())
  amount      Float
  description String
  date        DateTime        @default(now())
  type        TransactionType
  walletId    String
  wallet      Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  categoryId  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([walletId])
}

model store_sales {
  id           String   @id @default(cuid())
  pidStore     String   @unique
  pidProduct   String
  pidUser      String
  product_name String
  unit_price   String
  total_price  String
  quantity     String
  status       String
  ext1         String?
  ext2         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model store_sales_faya {
  id           Int    @id @default(autoincrement())
  pidStore     String @unique
  pidProduct   String
  pidUser      String
  product_name String
  unit_price   String
  total_price  String
  quantity     String

  activeTab        String?
  purchaseType     String? // 'single' or 'bulk'
  fullName         String?
  phone            String?
  address          String?
  deliveryOption   String?
  deliveryLocation String?

  status    String
  ext1      String?
  ext2      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum WalletType {
  MAIN
  SAVINGS
  CREDIT
  INVESTMENT
}

enum TransactionType {
  CREDIT
  DEBIT
  TRANSFER
}

model Account {
  id            String      @id @default(cuid())
  name          String
  pidAccount    String      @unique()
  accountName   String
  accountNumber String
  bankName      String
  first_name    String
  email         String
  customer_code String
  phone         String
  type          AccountType
  balance       Decimal?    @default(0)
  currency      String?     @default("NGN")
  color         String? // For UI customization
  icon          String? // Icon identifier
  isDefault     Boolean?    @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  userId        String
  user          users       @relation(fields: [userId], references: [pidUser], onDelete: Cascade)

  @@index([userId])
}

enum AccountType {
  CASH
  BANK
  CREDIT_CARD
  INVESTMENT
  SAVINGS
  OTHER
}

enum PayStatus {
  SAVED
  STARTED
  COMPLETED
  CANCELLED
}

model buy_products {
  id            Int          @id @default(autoincrement())
  pidProduct    String       @unique()
  pidCategory   String
  pidUser       String?
  productName   String?
  productPrice  Float?
  productInfo   String?
  productStatus String?
  pidAdmin      String?
  ext1          String?
  ext2          String?
  xStatus       String?
  createdAt     DateTime?    @default(now())
  updatedAt     DateTime?
  buy_category  buy_category @relation(fields: [pidCategory], references: [pidCategory], onDelete: Cascade)
}

model buy_category {
  id             Int            @id @default(autoincrement())
  pidCategory    String         @unique()
  pidUser        String?
  categoryName   String?
  categoryInfo   String?
  categoryStatus String?
  ext1           String?
  ext2           String?
  xStatus        String?
  createdAt      DateTime?      @default(now())
  updatedAt      DateTime?
  buy_products   buy_products[]
}

enum ProductCondition {
  BRAND_NEW
  PRE_OWNED
  REFURBISHED
  OPEN_BOX
}

enum WarrantyPeriod {
  MONTHS3
  MONTHS6
  MONTHS12
  MONTHS24
  MONTHS36
}

model corporate_gift_request {
  id                            Int      @id @default(autoincrement())
  pidRequest                    String   @unique()
  pidUser                       String?
  businessName                  String
  contactPersonFullName         String
  productOrItemNeeded           String
  detailedSpecifications        String   @db.LongText
  quantityNeeded                Int
  preferredQualityLevel         String
  brandingCustomizationRequired String
  expectedDeliveryDate          String
  finalDeliveryLocationNigeria  String
  contactEmail                  String
  whatsappNumber                String
  proceedTimeline               String?
  hearAboutSureImports          String?
  additionalNotes               String?  @db.LongText
  budgetRange                   String?
  referenceFileUrl              String?
  referenceFileName             String?
  logoFileUrl                   String?
  logoFileName                  String?
  status                        String   @default("Pending")
  cancellationReason            String?  @db.LongText
  handledByPidUser              String?
  handledByEmail                String?
  handledByName                 String?
  pageUrl                       String?
  utmSource                     String?
  utmMedium                     String?
  utmCampaign                   String?
  utmContent                    String?
  utmTerm                       String?
  submittedAt                   String?
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model invoice_settings {
  id                     Int      @id @default(autoincrement())
  pidSetting             String   @unique()
  businessName           String
  businessContactDetails String   @db.LongText
  footerNotes            String   @db.LongText
  status                 String?  @default("ACTIVE")
  createdByPidUser       String?
  updatedByPidUser       String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model invoices {
  id               Int                  @id @default(autoincrement())
  pidInvoice       String               @unique()
  invoiceNumber    String               @unique()
  pidUser          String
  customerName     String?
  customerEmail    String?
  customerPhone    String?
  currency         String               @default("NGN")
  subtotal         Decimal              @db.Decimal(18, 2)
  discountTotal    Decimal              @default(0) @db.Decimal(18, 2)
  taxTotal         Decimal              @default(0) @db.Decimal(18, 2)
  grandTotal       Decimal              @db.Decimal(18, 2)
  amountPaid       Decimal              @default(0) @db.Decimal(18, 2)
  balanceDue       Decimal              @db.Decimal(18, 2)
  status           String               @default("DRAFT")
  issuedAt         DateTime?
  dueAt            DateTime?
  paidAt           DateTime?
  headerSnapshot   String?              @db.LongText
  footerSnapshot   String?              @db.LongText
  notes            String?              @db.LongText
  linkedRequestId  String?
  createdByPidUser String?
  updatedByPidUser String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  user             users                @relation(fields: [pidUser], references: [pidUser], onDelete: Restrict)
  items            invoice_items[]
  payments         invoice_payments[]
  receipts         receipts[]
  auditLogs        invoice_audit_logs[]
  accessTokens     invoice_access_tokens[]
  paymentClaims    invoice_payment_claims[]
  followUps        invoice_follow_ups[]

  @@index([pidUser])
  @@index([status])
  @@index([createdAt])
  @@index([dueAt])
}

model invoice_follow_ups {
  id             Int      @id @default(autoincrement())
  pidFollowUp    String   @unique()
  pidInvoice     String
  followUpNumber Int
  subject        String
  status         String   @default("SENT")
  error          String?  @db.LongText
  sentAt         DateTime @default(now())
  createdAt      DateTime @default(now())
  invoice        invoices @relation(fields: [pidInvoice], references: [pidInvoice], onDelete: Cascade)

  @@index([pidInvoice])
  @@index([sentAt])
  @@index([status])
}

model invoice_access_tokens {
  id            Int      @id @default(autoincrement())
  pidToken      String   @unique()
  pidInvoice    String
  accessToken   String   @unique()
  expiresAt     DateTime
  lastUsedAt    DateTime?
  revokedAt     DateTime?
  createdByPidUser String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  invoice       invoices @relation(fields: [pidInvoice], references: [pidInvoice], onDelete: Cascade)

  @@index([pidInvoice])
  @@index([accessToken])
  @@index([expiresAt])
}

model invoice_bank_accounts {
  id             Int      @id @default(autoincrement())
  pidBankAccount String   @unique()
  accountName    String
  accountNumber  String
  bankName       String
  sortCode       String?
  currency       String   @default("NGN")
  country        String?
  notes          String?  @db.LongText
  displayOrder   Int      @default(0)
  status         String   @default("ACTIVE")
  createdByPidUser String?
  updatedByPidUser String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([currency])
  @@index([displayOrder])
}

model invoice_payment_claims {
  id                Int      @id @default(autoincrement())
  pidClaim          String   @unique()
  pidInvoice        String
  pidUser           String?
  claimedAmount     Decimal  @db.Decimal(18, 2)
  currency          String   @default("NGN")
  selectedBankAccountId String?
  selectedBankAccountJson String? @db.LongText
  paymentReference  String?
  note              String?  @db.LongText
  claimedAt         DateTime @default(now())
  status            String   @default("PENDING_CONFIRMATION")
  reviewedByPidUser String?
  reviewedAt        DateTime?
  reviewNote        String?  @db.LongText
  approvedInvoicePaymentPid String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  invoice           invoices @relation(fields: [pidInvoice], references: [pidInvoice], onDelete: Cascade)
  user              users?   @relation(fields: [pidUser], references: [pidUser], onDelete: SetNull)

  @@index([pidInvoice])
  @@index([pidUser])
  @@index([status])
  @@index([claimedAt])
}

model invoice_items {
  id             Int      @id @default(autoincrement())
  pidInvoiceItem String   @unique()
  pidInvoice     String
  lineNo         Int
  description    String   @db.LongText
  quantity       Decimal  @db.Decimal(18, 2)
  unitPrice      Decimal  @db.Decimal(18, 2)
  lineTotal      Decimal  @db.Decimal(18, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  invoice        invoices @relation(fields: [pidInvoice], references: [pidInvoice], onDelete: Cascade)

  @@index([pidInvoice])
}

model invoice_payments {
  id                Int        @id @default(autoincrement())
  pidInvoicePayment String     @unique()
  pidInvoice        String
  pidUser           String
  amount            Decimal    @db.Decimal(18, 2)
  currency          String     @default("NGN")
  paymentMethod     String
  reference         String?
  note              String?    @db.LongText
  paidAt            DateTime
  recordedByPidUser String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  invoice           invoices   @relation(fields: [pidInvoice], references: [pidInvoice], onDelete: Restrict)
  user              users      @relation(fields: [pidUser], references: [pidUser], onDelete: Restrict)
  receipts          receipts[]

  @@index([pidInvoice])
  @@index([pidUser])
  @@index([paidAt])
}

model receipts {
  id                Int              @id @default(autoincrement())
  pidReceipt        String           @unique()
  receiptNumber     String           @unique()
  pidInvoice        String
  pidInvoicePayment String
  amount            Decimal          @db.Decimal(18, 2)
  balanceAfter      Decimal          @db.Decimal(18, 2)
  issuedAt          DateTime         @default(now())
  deliveryStatus    String           @default("PENDING")
  sentAt            DateTime?
  createdByPidUser  String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  invoice           invoices         @relation(fields: [pidInvoice], references: [pidInvoice], onDelete: Restrict)
  payment           invoice_payments @relation(fields: [pidInvoicePayment], references: [pidInvoicePayment], onDelete: Restrict)

  @@index([pidInvoice])
  @@index([pidInvoicePayment])
  @@index([issuedAt])
}

model invoice_audit_logs {
  id          Int      @id @default(autoincrement())
  pidAuditLog String   @unique()
  pidInvoice  String
  pidUser     String?
  action      String
  oldStatus   String?
  newStatus   String?
  metadata    String?  @db.LongText
  createdAt   DateTime @default(now())
  invoice     invoices @relation(fields: [pidInvoice], references: [pidInvoice], onDelete: Cascade)
  user        users?   @relation(fields: [pidUser], references: [pidUser], onDelete: SetNull)

  @@index([pidInvoice])
  @@index([pidUser])
  @@index([createdAt])
}
